PORT=3000

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=import_user
MYSQL_PASSWORD=измените_пароль
MYSQL_DATABASE=import_service

# Подпись JWT (длинная случайная строка)
JWT_SECRET=измените_на_случайную_строку_32plus_символов

# Срок жизни токена (например 30d, 365d) — до выхода или истечения
JWT_EXPIRES_IN=30d

# Тот же токен, что 1С передаёт как: Authorization: Bearer <значение>
INTEGRATION_BEARER_TOKEN=измените_на_секрет_для_1с

# Чат по заявкам (realtime) + исходящий HTTP в 1С
# Секрет для локального broadcast (127.0.0.1) и для X-Broadcast-Secret
CHAT_BROADCAST_SECRET=измените_на_секрет_для_wss_broadcast
# Порт, на котором поднимается wss+локальный /broadcast
CHAT_BROADCAST_PORT=3010

# URL 1С для исходящих сообщений пользователя (пока можно оставить пустым, тогда доставка пометится failed)
ONE_C_CHAT_URL=
# Опционально: Bearer к 1С
ONE_C_CHAT_BEARER_TOKEN=
ONE_C_CHAT_TIMEOUT_MS=15000

# SMTP настройки для отправки заявок регистрации
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=example@gmail.com
SMTP_PASS=app_password
EMAIL_FROM=info@import-service.su
MAIL_TO=info@import-service.su
# Название в письмах заявок (по умолчанию: Импорт Сервис)
APP_NAME=Импорт Сервис

# Опционально: публичный origin для абсолютных ссылок в JSON (fileUrl, vehiclePhotoUrls, …)
# PUBLIC_BASE_URL=https://ваш-домен.ru

# Flutter Web админка (GET /admin/). По умолчанию: <корень сервера>/web
# ADMIN_WEB_ROOT=web
